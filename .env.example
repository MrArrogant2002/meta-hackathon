# Environment configuration for SQL Query Debugging Environment
# Copy this file to .env and fill in your actual tokens

# HuggingFace token for inference API (REQUIRED)
# Get yours at https://huggingface.co/settings/tokens
HF_TOKEN=your_hf_token_here

# Optional: override the default LLM model for baseline inference
# MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

# Optional: override the API endpoint
# API_BASE_URL=https://router.huggingface.co/v1

# Optional: override environment host (defaults to localhost:7860)
# ENV_HOST=http://localhost:7860
