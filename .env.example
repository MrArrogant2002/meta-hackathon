# Environment configuration for Customer Support Escalation Desk

# Hugging Face token or compatible router token for the OpenAI client
HF_TOKEN=your_hf_token_here

# Optional: override the model used by inference.py
# MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

# Optional: override the OpenAI-compatible API base URL
# API_BASE_URL=https://router.huggingface.co/v1

# Optional: override the environment host
# ENV_HOST=http://localhost:7860
